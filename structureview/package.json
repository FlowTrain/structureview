{
  "name": "structureview",
  "version": "0.1.0",
  "description": "A clean document-style viewer for Markdown and JSON files",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "icons": "node scripts/generate-icons.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality-gate": "npm run lint && npm run coverage",
    "ui:install": "npm --prefix ui install",
    "ui:dev": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "timc:test": "node src/timc-light/engine.selftest.mjs"
  },
  "keywords": [
    "markdown",
    "json",
    "viewer",
    "electron"
  ],
  "author": "James Gifford",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "jimp": "^1.6.1",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "highlight.js": "^11.9.0",
    "marked": "^11.0.0"
  },
  "overrides": {
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^4.2.0"
    }
  },
  "build": {
    "appId": "com.structureview.app",
    "productName": "StructureView",
    "icon": "build/icon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/**/*",
      "package.json",
      "!**/__tests__/**",
      "!**/*.test.js",
      "!ui/**"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown File",
        "role": "Viewer"
      },
      {
        "ext": "json",
        "name": "JSON File",
        "role": "Viewer"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "appx"
      ],
      "icon": "build/icon.ico"
    },
    "appx": {
      "assets": "build/appx",
      "applicationId": "StructureView",
      "backgroundColor": "#0a0a0f"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
